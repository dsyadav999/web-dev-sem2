<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Async Weather Tracker</title>

<style>
body {
margin: 0;
font-family: Arial, sans-serif;
background: #2e3565;
display: flex;
justify-content: center;
}

.container {
width: 800px;
padding: 20px;
color: white;
}

h2 {
text-align: center;
}

.grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 15px;
}

.card {
background: #f2f2f2;
color: #333;
padding: 15px;
border-radius: 8px;
}

.search-box {
display: flex;
gap: 10px;
}

input {
flex: 1;
padding: 8px;
}

button {
background: #ff6b2d;
border: none;
color: white;
padding: 8px 15px;
cursor: pointer;
}

button:hover {
opacity: 0.8;
}

.history-btn {
background: #ff6b2d;
color: white;
border: none;
padding: 4px 10px;
margin: 3px;
border-radius: 4px;
cursor: pointer;
}

.console {
margin-top: 15px;
background: #f2f2f2;
color: black;
padding: 10px;
border-radius: 8px;
}

pre {
background: #1e2453;
color: #8fffa3;
padding: 10px;
border-radius: 6px;
height: 120px;
overflow-y: auto;
}
</style>
</head>

<body>

<div class="container">
<h2>☀️ Async Weather Tracker</h2>

<div class="grid">
    <div class="card">
    <label>Search City</label>
    <div class="search-box">
        <input type="text" id="cityInput" placeholder="Enter city...">
        <button onclick="searchWeather()">Search</button>
    </div>

    <h4>Search History</h4>
    <div id="history"></div>
    </div>
    <div class="card">
    <h4>Weather Info</h4>
    <div id="weather">No data</div>
    </div>
</div>

<div class="console">
    <h4>Console – Event Loop</h4>
    <pre id="consoleBox"></pre>
</div>
</div>

<script>
const API_KEY = "648bddfd52a7e63277d8c2fff6d8d894";

const weatherBox = document.getElementById("weather");
const historyBox = document.getElementById("history");
const consoleBox = document.getElementById("consoleBox");
function log(msg) {
console.log(msg);
consoleBox.textContent += msg + "\\n";
}

window.onload = () => {
loadHistory();
log("Page Loaded (Sync)");
};

async function searchWeather(cityName) {
const input = document.getElementById("cityInput");
const city = cityName || input.value.trim();

if (!city) {
    alert("Enter city name");
    return;
}

log("Sync Start");
log("Before Fetch (Call Stack)");

try {
    const data = await fetchWeather(city);
    showWeather(data);
    saveHistory(city);
    loadHistory();
    log("After Fetch (Microtask Queue)");
} catch (err) {
    weatherBox.innerHTML = "<span style='color:red'>City not found</span>";
    log("Error Caught: " + err.message);
}

log("Sync End");
}


function fetchWeather(city) {
log("Fetching API...");

return fetch(
    `https://api.openweathermap.org/data/2.5/weather?q=${city}&appid=${API_KEY}&units=metric`
)
    .then(res => {
    log("Promise Resolved (.then)");
    if (!res.ok) throw new Error("Invalid City");
    return res.json();
    })
    .catch(err => {
    log("Promise Rejected (.catch)");
    throw err;
    });
}
function showWeather(data) {
weatherBox.innerHTML = `
    <p><b>City:</b> ${data.name}</p>
    <p><b>Temp:</b> ${data.main.temp} °C</p>
    <p><b>Weather:</b> ${data.weather[0].main}</p>
    <p><b>Humidity:</b> ${data.main.humidity}%</p>
    <p><b>Wind:</b> ${data.wind.speed} m/s</p>
`;
}
function saveHistory(city) {
let history = JSON.parse(localStorage.getItem("cities")) || [];
if (!history.includes(city)) {
    history.unshift(city);
    localStorage.setItem("cities", JSON.stringify(history));
}
}

function loadHistory() {
let history = JSON.parse(localStorage.getItem("cities")) || [];
historyBox.innerHTML = "";

history.forEach(city => {
    const btn = document.createElement("button");
    btn.className = "history-btn";
    btn.textContent = city;
    btn.onclick = () => searchWeather(city);
    historyBox.appendChild(btn);
});
}
</script>

</body>
</html>
